# ── App ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_generate_with_openssl_rand_base64_32

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://marketing:marketing@localhost:5432/marketing_dev

# ── Storage ──────────────────────────────────────────────────────────
STORAGE_DRIVER=local
# STORAGE_DRIVER=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=marketing-assets
LOCAL_UPLOAD_DIR=./public/uploads

# ── Meta (Facebook / Instagram) ──────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=change_me_random_string

# ── Email (dev → MailHog) ────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@youragency.com

# ── Cron ─────────────────────────────────────────────────────────────
CRON_SECRET=change_me_random_string

# ── Banco Inter ───────────────────────────────────────────────────────
# Chave para criptografar credenciais Inter no banco (AES-256)
# Gere com: openssl rand -base64 32
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_32

# URL pública para receber webhooks do Banco Inter (deve ser HTTPS)
# Configure no portal Inter: https://developers.inter.co
INTER_WEBHOOK_URL=https://yourdomain.com/api/webhooks/inter
